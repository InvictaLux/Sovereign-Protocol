# Firebase Configuration
VITE_FIREBASE_API_KEY=your_actual_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef1234567890
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# App Configuration
VITE_APP_ID=sovereign-protocol-v1

# IPFS/Pinata Configuration
VITE_PINATA_API_KEY=your_pinata_api_key_here
VITE_PINATA_SECRET_KEY=your_pinata_secret_key_here

# Lit Protocol Configuration (Optional - defaults to testnet)
VITE_LIT_NETWORK=cayenne

# Phase 2 - On-chain Purchase Configuration
VITE_SOVEREIGN_CONTRACT_ADDRESS=0xYourContractAddress
VITE_SOVEREIGN_CHAIN_ID=0xaa36a7

# Functions runtime config (set via secure environment, not frontend)
# ETH_RPC_URL=https://sepolia.infura.io/v3/your_project_id
# SOVEREIGN_CHAIN_ID=0xaa36a7
